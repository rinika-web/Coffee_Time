@import "tailwindcss";

/* ---------------------------------------------------
   Core document setup
--------------------------------------------------- */

html,
body {
  height: 100%;
}

html {
  scroll-behavior: smooth;
  background-color: #1c1c1c;
}

/* ---------------------------------------------------
   Background layers (DO NOT AFFECT SCROLL)
--------------------------------------------------- */

/* Grain texture (TILED, NOT STRETCHED) */
html::before {
  content: "";
  position: fixed;
  inset: 0;

  background-image: url("/features/Coffee/grain3.jpg");
  /* background-repeat: repeat;*/
  background-size: 200px; /* smaller = denser grain */

  opacity: 0.07; /* correct grain strength 
  mix-blend-mode: overlay;*/
background-size: cover;
overflow: hidden;
  pointer-events: none;
  z-index: 1;
}

/* Vignette */
html::after {
  content: "";
  position: fixed;
  inset: 0;

  background: radial-gradient(
    ellipse at center,
    rgba(0, 0, 0, 0) 85%,
    rgb(0, 0, 0) 100%
  );

  animation: vignetteBreath 24s ease-in-out infinite;
  pointer-events: none;
  z-index: -1;
}

/* ---------------------------------------------------
   Theme variables
--------------------------------------------------- */

:root {
  --background: #1c1c1c;
  --foreground: #FFFBEB;

  --light: #FFFBEB;
  --dark: #030000;
}

@theme inline {
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --font-sans: var(--font-geist-sans);
  --font-mono: var(--font-geist-mono);
}

/* ---------------------------------------------------
   Body (CONTENT ONLY)
--------------------------------------------------- */

body {
  min-height: 100vh;
  background-color: transparent;
  color: var(--foreground);
  font-family: Arial, Helvetica, sans-serif;
  overflow-x: hidden;
}

/* ---------------------------------------------------
   Typography helpers
--------------------------------------------------- */

.bellefair-regular {
  font-family: "Bellefair", serif;
}

.dancing {
  font-family: "Dancing Script", cursive;
}

/* ---------------------------------------------------
   Vignette animation
--------------------------------------------------- */

@keyframes vignetteBreath {
  0% {
    opacity: 0.45;
  }
  50% {
    opacity: 0.6;
  }
  100% {
    opacity: 0.45;
  }
}




@import "tailwindcss";

/* ---------------------------------------------------
   Core document setup
--------------------------------------------------- */

html,
body {
  height: 100%;
}

html {
  scroll-behavior: smooth;
  background-color: #1c1c1c; /* base charcoal */
}

/* ---------------------------------------------------
   Background layers (THE CORRECT WAY)
   These never touch layout or scroll
--------------------------------------------------- */

/* Grain texture */
html::before {
  content: "";
  position: fixed;
  inset: 0;
  background-image: url("/features/Coffee/grain.jpg");
 /* background-repeat: repeat;*/
  opacity: 0.05;
  pointer-events: none;
  z-index: -2;
  }

 /* body::before { 
    content: ""; 
    position: fixed; 
    inset: 0; 
    background-image: url("/features/Coffee/grain.jpg"); 
    pointer-events: none; 
    z-index: 0; }
*/

/* Vignette */
html::after {
  content: "";
  position: fixed;
  inset: 0;
  background: radial-gradient(
    ellipse at center,
    rgba(0, 0, 0, 0) 40%,
    rgba(0, 0, 0, 0.55) 100%
  );
  animation: vignetteBreath 24s ease-in-out infinite;
  pointer-events: none;
  z-index: -1;
}

/* ---------------------------------------------------
   Theme variables
--------------------------------------------------- */

:root {
  --background: #1c1c1c;
  --foreground: #FFFBEB;

  --light: #FFFBEB;
  --dark: #030000;
}

@theme inline {
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --font-sans: var(--font-geist-sans);
  --font-mono: var(--font-geist-mono);
}

/* Lock theme (avoid OS overrides) */
@media (prefers-color-scheme: dark) {
  :root {
    --background: #1c1c1c;
    --foreground: #FFFBEB;
  }
}

/* ---------------------------------------------------
   Body (CONTENT ONLY — NO LAYERS)
--------------------------------------------------- */

body {
  min-height: 100vh;
  background-color: transparent; /* important */
  color: var(--foreground);
  font-family: Arial, Helvetica, sans-serif;
  overflow-x: hidden;
}

/* ---------------------------------------------------
   Typography helpers
--------------------------------------------------- */

.bellefair-regular {
  font-family: "Bellefair", serif;
  font-weight: 400;
}

.dancing {
  font-family: "Dancing Script", cursive;
}

/* ---------------------------------------------------
   Vignette animation
--------------------------------------------------- */

@keyframes vignetteBreath {
  0% {
    opacity: 0.45;
  }
  50% {
    opacity: 0.6;
  }
  100% {
    opacity: 0.45;
  }
}



